/* detail */

/* pages/product/detail/index.wxss - 商品详情页样式 */

.detail-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* ===== 图片轮播 ===== */
.image-swiper-wrap {
  position: relative;
  width: 100%;
  height: 750rpx;
  background: #F0F0F0;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
}

/* swiper-item 内部元素需要撑满 */
.image-swiper .wx-swiper-item,
.image-swiper swiper-item {
  width: 100%;
  height: 100%;
}

.swiper-img {
  width: 100%;
  height: 750rpx;
}

.image-indicator {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}

.indicator-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 无图片占位 */
.img-placeholder {
  width: 100%;
  height: 100%;
  min-height: 750rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.img-placeholder-1 {
  background: linear-gradient(135deg, #F0F4FF 0%, #E8EEFF 100%);
}

.img-placeholder-2 {
  background: linear-gradient(135deg, #FFF4F0 0%, #FFE8E0 100%);
}

.img-placeholder-3 {
  background: linear-gradient(135deg, #F0FFF4 0%, #E0FFE8 100%);
}

.img-placeholder-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.img-placeholder-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #555555;
  margin-bottom: 10rpx;
}

.img-placeholder-text {
  font-size: 24rpx;
  color: #BBBBBB;
}

.sold-out-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sold-out-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: 6rpx solid #FFFFFF;
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  letter-spacing: 8rpx;
}

/* ===== 商品信息卡片 ===== */
.info-card {
  background: #FFFFFF;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #FF4444;
  font-weight: bold;
}

.price-num {
  font-size: 56rpx;
  color: #FF4444;
  font-weight: bold;
  line-height: 1;
}

.original-price {
  font-size: 26rpx;
  color: #BBBBBB;
  text-decoration: line-through;
  align-self: flex-end;
  margin-bottom: 4rpx;
}

.sale-badge {
  background: #FF4444;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  align-self: flex-end;
  margin-bottom: 4rpx;
}

.sale-text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.product-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #222222;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #AAAAAA;
}

.meta-divider {
  font-size: 22rpx;
  color: #DDDDDD;
}

.meta-sold-out {
  color: #FF4444;
}

/* ===== 通用区块卡片 ===== */
.section-card {
  background: #FFFFFF;
  margin-bottom: 16rpx;
  padding: 28rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

/* ===== 数量控制 ===== */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  overflow: hidden;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn text {
  font-size: 36rpx;
  color: #333333;
  line-height: 1;
}

.qty-btn-disabled {
  opacity: 0.35;
}

.qty-input {
  width: 88rpx;
  height: 72rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333333;
  border-left: 1rpx solid #EEEEEE;
  border-right: 1rpx solid #EEEEEE;
}

/* ===== 商品详情富文本 ===== */
.rich-content {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
}

.detail-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.placeholder-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #BBBBBB;
}

/* ===== 加载中 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #F0F0F0;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #AAAAAA;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.cart-entry {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: #FFF0EB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon {
  font-size: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #FF4444;
  color: #FFFFFF;
  font-size: 18rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.btn-cart {
  flex: 1;
  height: 88rpx;
  background: #FF8C5A;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cart text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.btn-buy {
  flex: 1;
  height: 88rpx;
  background: #FF4444;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-buy text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.btn-disabled {
  opacity: 0.5;
}
