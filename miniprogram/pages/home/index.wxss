/* pages/home/index.wxss - 首页样式 */

.home-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #FF6B35;
  padding: 16rpx 24rpx;
}

.search-inner {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #BBBBBB;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-item {
  width: 100%;
  height: 320rpx;
}

.banner-placeholder {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 优惠券横幅 */
.coupon-banner {
  background: linear-gradient(90deg, #FF4444, #FF6B35);
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.coupon-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.coupon-text {
  flex: 1;
  font-size: 26rpx;
  color: #FFFFFF;
}

.coupon-btn {
  font-size: 24rpx;
  color: #FFE0B2;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 区块卡片 */
.section-card {
  background: #FFFFFF;
  margin: 16rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  overflow: hidden;
}

/* 区块头部 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: baseline;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
}

.section-more {
  font-size: 24rpx;
  color: #FF6B35;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: #FFF0EB;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.category-emoji {
  font-size: 48rpx;
}

.category-name {
  font-size: 22rpx;
  color: #666666;
  text-align: center;
}

/* 限时特惠滚动 */
.flash-scroll {
  white-space: nowrap;
}

.flash-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 4rpx;
}

.flash-item {
  width: 200rpx;
  display: inline-flex;
  flex-direction: column;
  flex-shrink: 0;
}

/* 商品图片 */
.product-img-wrap {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F5F5F5;
  margin-bottom: 12rpx;
}

.flash-item .product-img-wrap {
  width: 200rpx;
  height: 200rpx;
  padding-top: 0;
}

.product-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.flash-item .product-img {
  position: static;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.sale-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: #FF4444;
  color: #FFFFFF;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.product-name {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #FF4444;
  font-weight: bold;
}

.price-num {
  font-size: 30rpx;
  color: #FF4444;
  font-weight: bold;
}

.original-price {
  font-size: 20rpx;
  color: #CCCCCC;
  text-decoration: line-through;
}

/* 营销横幅 */
.marketing-banner {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
}

.marketing-item {
  flex: 1;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.marketing-left {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}

.marketing-right {
  background: linear-gradient(135deg, #2196F3, #42A5F5);
}

.marketing-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.marketing-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background: #FAFAFA;
  border-radius: 16rpx;
  overflow: hidden;
}

.product-info {
  padding: 16rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.add-cart-btn {
  width: 52rpx;
  height: 52rpx;
  background: #FF6B35;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}
