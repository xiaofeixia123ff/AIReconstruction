/* pages/order/detail/index.wxss - 订单详情页样式 */

.detail-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* ===== 状态横幅 ===== */
.status-banner {
  padding: 40rpx 32rpx 48rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 通用区块卡片 ===== */
.section-card {
  background: #FFFFFF;
  margin-bottom: 16rpx;
  padding: 0 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  padding: 24rpx 0 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

/* ===== 收货地址 ===== */
.address-row {
  padding: 20rpx 0;
}

.address-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #222222;
}

.address-phone {
  font-size: 28rpx;
  color: #555555;
}

.address-detail {
  font-size: 26rpx;
  color: #777777;
  line-height: 1.5;
  display: block;
}

/* ===== 商品列表 ===== */
.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #F5F5F5;
}

.goods-img {
  width: 100%;
  height: 100%;
}

.goods-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 26rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.goods-bottom {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goods-price {
  font-size: 24rpx;
  color: #999999;
}

.goods-qty {
  font-size: 24rpx;
  color: #AAAAAA;
}

.goods-subtotal {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ===== 订单信息行 ===== */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.info-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  text-align: right;
  flex: 1;
}

.copy-btn {
  font-size: 22rpx;
  color: #FF4444;
  border: 1rpx solid #FF4444;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}

/* ===== 价格明细 ===== */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.price-row:last-child {
  border-bottom: none;
}

.price-row-total {
  padding-top: 24rpx;
}

.price-label {
  font-size: 26rpx;
  color: #666666;
}

.price-value {
  font-size: 26rpx;
  color: #333333;
}

.price-label-total {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.pay-price-wrap {
  display: flex;
  align-items: baseline;
}

.pay-symbol {
  font-size: 26rpx;
  color: #FF4444;
  font-weight: bold;
}

.pay-price {
  font-size: 44rpx;
  color: #FF4444;
  font-weight: bold;
}

/* ===== 加载中 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #AAAAAA;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-btn {
  height: 80rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.action-btn-outline {
  border: 1rpx solid #DDDDDD;
  color: #666666;
}

.action-btn-primary {
  background: #FF4444;
  color: #FFFFFF;
  font-weight: bold;
}
