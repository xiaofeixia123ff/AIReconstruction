<!--pages/order/list/index.wxml - 订单列表页-->
<view class="order-list-page">

  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === index ? 'tab-item-active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      <text class="tab-text">{{item.label}}</text>
      <view class="tab-line" wx:if="{{activeTab === index}}"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view
    class="order-scroll"
    scroll-y
    bindscrolltolower="onReachBottom"
  >
    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{isEmpty && !loading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无相关订单</text>
    </view>

    <!-- 订单卡片 -->
    <view
      class="order-card"
      wx:for="{{orders}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <!-- 卡片头部：订单号 + 状态 -->
      <view class="card-header">
        <text class="order-no">订单号：{{item.orderNo || item.id}}</text>
        <text class="order-status" style="color: {{item.statusColor}}">{{item.statusLabel}}</text>
      </view>

      <!-- 商品信息 -->
      <view class="goods-row" wx:if="{{item.coverItem}}">
        <view class="goods-img-wrap">
          <image
            wx:if="{{item.coverItem.product && item.coverItem.product.mainImage}}"
            class="goods-img"
            src="{{item.coverItem.product.mainImage}}"
            mode="aspectFill"
          />
          <view wx:else class="goods-img-placeholder">
            <text>🛍️</text>
          </view>
        </view>
        <view class="goods-info">
          <text class="goods-name">
            {{item.coverItem.product && item.coverItem.product.name || item.coverItem.name || '商品'}}
          </text>
          <text class="goods-qty" wx:if="{{item.itemCount > 1}}">共{{item.itemCount}}件商品</text>
        </view>
      </view>

      <!-- 卡片底部：时间 + 金额 + 操作 -->
      <view class="card-footer">
        <text class="order-time">{{item.createdAtStr}}</text>
        <view class="footer-right">
          <text class="order-amount">合计 ¥{{item.totalAmountStr}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-row" catchtap="stopPropagation">
        <!-- 待付款：取消订单 -->
        <view
          class="action-btn action-btn-outline"
          wx:if="{{item.status === 'pending'}}"
          catchtap="cancelOrder"
          data-id="{{item.id}}"
        >
          取消订单
        </view>
        <!-- 已发货：确认收货 -->
        <view
          class="action-btn action-btn-primary"
          wx:if="{{item.status === 'shipped'}}"
          catchtap="confirmReceive"
          data-id="{{item.id}}"
        >
          确认收货
        </view>
        <!-- 查看详情 -->
        <view
          class="action-btn action-btn-outline"
          catchtap="goDetail"
          data-id="{{item.id}}"
        >
          查看详情
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading && orders.length > 0}}">
      <text class="load-more-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && orders.length > 0}}">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>
  </scroll-view>

</view>
