/* pages/order/list/index.wxss - 订单列表页样式 */

.order-list-page {
  background: #F5F5F5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===== Tab 栏 ===== */
.tab-bar {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 0;
  position: relative;
}

.tab-text {
  font-size: 26rpx;
  color: #999999;
  padding-bottom: 20rpx;
}

.tab-item-active .tab-text {
  color: #FF4444;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #FF4444;
  border-radius: 2rpx;
}

/* ===== 滚动区域 ===== */
.order-scroll {
  flex: 1;
  height: calc(100vh - 88rpx);
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #AAAAAA;
}

/* ===== 订单卡片 ===== */
.order-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 16rpx 24rpx 0;
  overflow: hidden;
}

.order-card:last-child {
  margin-bottom: 24rpx;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 16rpx;
  border-bottom: 1rpx solid #F8F8F8;
}

.order-no {
  font-size: 22rpx;
  color: #AAAAAA;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

/* 商品行 */
.goods-row {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
}

.goods-img-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #F5F5F5;
}

.goods-img {
  width: 100%;
  height: 100%;
}

.goods-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 26rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.goods-qty {
  font-size: 22rpx;
  color: #AAAAAA;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid #F8F8F8;
}

.order-time {
  font-size: 22rpx;
  color: #AAAAAA;
}

.order-amount {
  font-size: 26rpx;
  color: #333333;
  font-weight: bold;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 28rpx 24rpx;
  gap: 16rpx;
}

.action-btn {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.action-btn-outline {
  border: 1rpx solid #DDDDDD;
  color: #666666;
}

.action-btn-primary {
  background: #FF4444;
  color: #FFFFFF;
  font-weight: bold;
}

/* ===== 加载更多 ===== */
.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text,
.no-more-text {
  font-size: 24rpx;
  color: #CCCCCC;
}
