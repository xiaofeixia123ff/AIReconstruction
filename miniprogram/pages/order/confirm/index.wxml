<!--pages/order/confirm/index.wxml - 确认订单页-->
<view class="confirm-page">

  <!-- 收货地址 -->
  <view class="address-card" bindtap="goSelectAddress">
    <view wx:if="{{address}}" class="address-content">
      <view class="address-top">
        <text class="address-name">{{address.name}}</text>
        <text class="address-phone">{{address.phone}}</text>
      </view>
      <text class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</text>
    </view>
    <view wx:else class="address-empty">
      <text class="address-empty-icon">📍</text>
      <text class="address-empty-text">请选择收货地址</text>
    </view>
    <text class="address-arrow">›</text>
  </view>

  <!-- 商品列表 -->
  <view class="section-card">
    <view class="section-title">商品清单</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{items}}" wx:key="id">
        <!-- 商品图片 -->
        <view class="goods-img-wrap">
          <image
            wx:if="{{item.mainImage}}"
            class="goods-img"
            src="{{item.mainImage}}"
            mode="aspectFill"
          />
          <view wx:else class="goods-img-placeholder">
            <text>🛍️</text>
          </view>
        </view>
        <!-- 商品信息 -->
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-bottom">
            <text class="goods-price">¥{{item.priceStr}}</text>
            <text class="goods-qty">×{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 优惠券 -->
  <view class="section-card" bindtap="openCouponPicker">
    <view class="row-item">
      <text class="row-label">优惠券</text>
      <view class="row-right">
        <text class="coupon-selected" wx:if="{{selectedCoupon}}">已优惠 ¥{{discountAmountStr}}</text>
        <text class="coupon-none" wx:elif="{{coupons.length > 0}}">{{coupons.length}}张可用</text>
        <text class="coupon-none" wx:else>暂无可用</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-card">
    <view class="row-item">
      <text class="row-label">备注</text>
      <input
        class="remark-input"
        placeholder="选填，留言给商家"
        placeholder-class="remark-placeholder"
        value="{{remark}}"
        bindinput="onRemarkInput"
        maxlength="100"
      />
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="section-card price-card">
    <view class="price-row">
      <text class="price-label">商品总价</text>
      <text class="price-value">¥{{totalPriceStr}}</text>
    </view>
    <view class="price-row" wx:if="{{discountAmount > 0}}">
      <text class="price-label">优惠券</text>
      <text class="price-value price-discount">-¥{{discountAmountStr}}</text>
    </view>
    <view class="price-row price-row-total">
      <text class="price-label-total">实付金额</text>
      <view class="pay-price-wrap">
        <text class="pay-symbol">¥</text>
        <text class="pay-price">{{payPriceStr}}</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view style="height: 140rpx;"></view>
</view>

<!-- 底部提交栏 -->
<view class="bottom-bar">
  <view class="total-wrap">
    <text class="total-label">合计：</text>
    <text class="total-symbol">¥</text>
    <text class="total-price">{{payPriceStr}}</text>
  </view>
  <view
    class="submit-btn {{submitting ? 'submit-btn-disabled' : ''}}"
    bindtap="submitOrder"
  >
    <text>{{submitting ? '提交中...' : '提交订单'}}</text>
  </view>
</view>

<!-- 优惠券选择弹窗 -->
<view class="coupon-mask" wx:if="{{showCouponPicker}}" bindtap="closeCouponPicker"></view>
<view class="coupon-panel {{showCouponPicker ? 'coupon-panel-show' : ''}}">
  <view class="coupon-panel-header">
    <text class="coupon-panel-title">选择优惠券</text>
    <text class="coupon-panel-close" bindtap="closeCouponPicker">✕</text>
  </view>
  <!-- 不使用优惠券 -->
  <view class="coupon-item coupon-item-none" bindtap="clearCoupon">
    <text class="coupon-none-text">不使用优惠券</text>
    <text class="coupon-check" wx:if="{{!selectedCoupon}}">✓</text>
  </view>
  <!-- 优惠券列表 -->
  <scroll-view class="coupon-list" scroll-y>
    <view
      class="coupon-item {{selectedCoupon && selectedCoupon.id === item.id ? 'coupon-item-active' : ''}}"
      wx:for="{{coupons}}"
      wx:key="id"
      bindtap="selectCoupon"
      data-coupon="{{item}}"
    >
      <view class="coupon-left">
        <view class="coupon-value-wrap">
          <text class="coupon-symbol">¥</text>
          <text class="coupon-value">{{item.valueStr}}</text>
        </view>
        <text class="coupon-condition" wx:if="{{item.minAmount}}">满{{item.minAmountStr}}元可用</text>
        <text class="coupon-condition" wx:else>无门槛</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-name">{{item.name}}</text>
        <text class="coupon-expire" wx:if="{{item.expireTime}}">{{item.expireDateStr}} 到期</text>
      </view>
      <text class="coupon-check" wx:if="{{selectedCoupon && selectedCoupon.id === item.id}}">✓</text>
    </view>
  </scroll-view>
</view>
