<!--pages/login/index.wxml - 登录页-->
<view class="login-page">
  <!-- 顶部装饰 -->
  <view class="login-header">
    <view class="logo-wrap">
      <text class="logo-icon">🛒</text>
    </view>
    <text class="app-name">鲜果超市</text>
    <text class="app-slogan">新鲜食材，送达到家</text>
  </view>

  <!-- 登录区域 -->
  <view class="login-body">
    <view class="login-card">
      <text class="login-title">欢迎回来</text>
      <text class="login-desc">登录后享受会员专属福利</text>

      <!-- 微信登录按鈕 -->
      <button
        class="btn-wx-login"
        bindtap="handleWxLogin"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        <text class="wx-icon">💬</text>
        <text>微信一键登录</text>
      </button>

      <!-- 跳过登录 -->
      <view class="skip-wrap" bindtap="handleSkip">
        <text class="skip-text">暂不登录，游客浏览</text>
        <text class="skip-arrow">›</text>
      </view>
    </view>

    <!-- 福利列表 -->
    <view class="benefits-wrap">
      <view class="benefit-item">
        <text class="benefit-icon">🎁</text>
        <text class="benefit-text">专属优惠券</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">📦</text>
        <text class="benefit-text">订单跟踪</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">⭐</text>
        <text class="benefit-text">会员积分</text>
      </view>
    </view>
  </view>

  <!-- 隐私政策 -->
  <view class="privacy-wrap">
    <text class="privacy-text">登录即表示同意 </text>
    <text class="privacy-link">用户协议</text>
    <text class="privacy-text"> 和 </text>
    <text class="privacy-link">隐私政策</text>
  </view>
</view>
