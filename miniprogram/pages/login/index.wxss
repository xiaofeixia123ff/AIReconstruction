/* pages/login/index.wxss - 登录页样式 */

.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #FF6B35 0%, #FF8C5A 40%, #FFF0EB 70%, #F5F5F5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* 顶部 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 60rpx;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.logo-icon {
  font-size: 72rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 登录卡片 */
.login-body {
  width: 100%;
}

.login-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

.login-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.login-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

/* 微信登录按鈕 */
.btn-wx-login {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 32rpx;
}
.btn-wx-login::after {
  border: none;
}

.wx-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 跳过登录 */
.skip-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
}

.skip-text {
  font-size: 26rpx;
  color: #999999;
}

.skip-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  margin-left: 4rpx;
}

/* 福利 */
.benefits-wrap {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  backdrop-filter: blur(10px);
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.benefit-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.benefit-text {
  font-size: 24rpx;
  color: #666666;
}

/* 隐私政策 */
.privacy-wrap {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 40rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.privacy-link {
  font-size: 22rpx;
  color: #FFFFFF;
  text-decoration: underline;
}
