<!--pages/address/edit/index.wxml - 地址编辑页-->
<view class="edit-page">

  <!-- 定位按钮 -->
  <view class="locate-btn" bindtap="autoLocate">
    <text class="locate-icon">📍</text>
    <text class="locate-text">点击自动定位填写地址</text>
    <text class="locate-arrow">›</text>
  </view>

  <view class="form-card">
    <!-- 收货人 -->
    <view class="form-row">
      <text class="form-label">收货人</text>
      <input
        class="form-input"
        placeholder="请填写收货人姓名"
        placeholder-class="form-placeholder"
        value="{{form.name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-row">
      <text class="form-label">手机号码</text>
      <input
        class="form-input"
        type="number"
        placeholder="请填写手机号码"
        placeholder-class="form-placeholder"
        value="{{form.phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <!-- 省市区 -->
    <view class="form-row">
      <text class="form-label">所在地区</text>
      <picker
        mode="region"
        value="{{regionValue}}"
        bindchange="onRegionChange"
        class="region-picker"
      >
        <view class="picker-value">
          <text wx:if="{{form.province}}">{{form.province}} {{form.city}} {{form.district}}</text>
          <text wx:else class="form-placeholder">请选择省市区</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 详细地址 -->
    <view class="form-row form-row-textarea">
      <text class="form-label">详细地址</text>
      <textarea
        class="form-textarea"
        placeholder="街道、楼牌号等"
        placeholder-class="form-placeholder"
        value="{{form.detail}}"
        bindinput="onDetailInput"
        maxlength="100"
        auto-height
      />
    </view>
  </view>

  <!-- 设为默认 -->
  <view class="default-row" bindtap="toggleDefault">
    <text class="default-label">设为默认收货地址</text>
    <view class="switch-wrap {{form.isDefault ? 'switch-on' : 'switch-off'}}">
      <view class="switch-thumb"></view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view style="height: 140rpx;"></view>
</view>

<!-- 底部保存按钮 -->
<view class="bottom-bar">
  <view class="save-btn" bindtap="saveAddress">保存地址</view>
</view>
