/* pages/address/index.wxss - 地址列表页样式 */

.address-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #AAAAAA;
  margin-bottom: 48rpx;
}

.empty-add-btn {
  height: 88rpx;
  padding: 0 80rpx;
  background: #FF4444;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ===== 地址列表 ===== */
.address-list {
  padding: 16rpx 0;
}

.address-item {
  background: #FFFFFF;
  margin: 0 0 16rpx;
  padding: 28rpx 28rpx 0;
}

/* 地址信息 */
.addr-info {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.addr-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #222222;
}

.addr-phone {
  font-size: 28rpx;
  color: #555555;
}

.default-tag {
  font-size: 20rpx;
  color: #FF4444;
  border: 1rpx solid #FF4444;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.addr-detail {
  font-size: 26rpx;
  color: #777777;
  line-height: 1.5;
  display: block;
}

/* 操作按钮行 */
.addr-actions {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 32rpx;
}

.action-default,
.action-edit,
.action-delete {
  font-size: 24rpx;
  padding: 8rpx 0;
}

.action-default {
  color: #999999;
}

.action-default-active {
  color: #FF4444;
}

.action-edit {
  color: #666666;
}

.action-delete {
  color: #FF4444;
  margin-left: auto;
}

/* ===== 底部添加按钮 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.add-btn {
  height: 96rpx;
  background: #FF4444;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.add-icon {
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}
