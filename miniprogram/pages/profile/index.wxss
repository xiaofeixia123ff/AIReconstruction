/* pages/profile/index.wxss - 我的页面样式 */

.profile-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* ===== 用户头部 ===== */
.user-header {
  background: linear-gradient(135deg, #FF6B35, #FF4444);
  padding: 60rpx 28rpx 40rpx;
}

/* 未登录 */
.user-unlogin {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.unlogin-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.unlogin-title {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.unlogin-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 已登录 */
.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 60rpx;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 积分余额 */
.user-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ===== 通用卡片 ===== */
.section-card {
  background: #FFFFFF;
  margin: 16rpx 0 0;
}

/* ===== 我的订单 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #222222;
  font-weight: bold;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.section-more-text {
  font-size: 24rpx;
  color: #999999;
}

.section-more-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.order-tabs {
  display: flex;
  padding: 0 0 28rpx;
}

.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0;
}

.order-tab-icon {
  font-size: 48rpx;
}

.order-tab-label {
  font-size: 22rpx;
  color: #666666;
}

/* ===== 菜单列表 ===== */
.menu-card {
  margin-top: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  gap: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* ===== 退出登录 ===== */
.logout-btn {
  margin: 40rpx 28rpx 0;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #FF4444;
  border: 1rpx solid #FFCCCC;
}
