<!--pages/profile/index.wxml - 我的页面-->
<view class="profile-page">

  <!-- 用户信息头部 -->
  <view class="user-header">
    <!-- 未登录 -->
    <view class="user-unlogin" wx:if="{{!isLogin}}" bindtap="goLogin">
      <view class="avatar-placeholder">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="unlogin-info">
        <text class="unlogin-title">点击登录</text>
        <text class="unlogin-desc">登录后享受更多服务</text>
      </view>
      <text class="header-arrow">›</text>
    </view>

    <!-- 已登录 -->
    <view class="user-info" wx:else>
      <view class="avatar-wrap">
        <image
          wx:if="{{userInfo.avatarUrl}}"
          class="avatar"
          src="{{userInfo.avatarUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-icon">👤</text>
        </view>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '用户'}}</text>
        <text class="user-phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
        <text class="user-phone" wx:else>未绑定手机号</text>
      </view>
    </view>

    <!-- 积分/余额 -->
    <view class="user-stats" wx:if="{{isLogin && userInfo}}">
      <view class="stat-item">
        <text class="stat-value">{{userInfo.points || 0}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{userInfo.balance || '0.00'}}</text>
        <text class="stat-label">余额</text>
      </view>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-more" bindtap="goOrders" data-tab="">
        <text class="section-more-text">全部订单</text>
        <text class="section-more-arrow">›</text>
      </view>
    </view>
    <view class="order-tabs">
      <view class="order-tab" bindtap="goOrders" data-tab="pending">
        <text class="order-tab-icon">💳</text>
        <text class="order-tab-label">待付款</text>
      </view>
      <view class="order-tab" bindtap="goOrders" data-tab="paid">
        <text class="order-tab-icon">📦</text>
        <text class="order-tab-label">待发货</text>
      </view>
      <view class="order-tab" bindtap="goOrders" data-tab="shipped">
        <text class="order-tab-icon">🚚</text>
        <text class="order-tab-label">待收货</text>
      </view>
      <view class="order-tab" bindtap="goOrders" data-tab="completed">
        <text class="order-tab-icon">✅</text>
        <text class="order-tab-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="section-card menu-card">
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-label">收货地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCoupons">
      <text class="menu-icon">🎫</text>
      <text class="menu-label">我的优惠券</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" wx:if="{{isLogin}}" bindtap="logout">
    退出登录
  </view>

  <!-- 底部安全区 -->
  <view style="height: 40rpx;"></view>
</view>
