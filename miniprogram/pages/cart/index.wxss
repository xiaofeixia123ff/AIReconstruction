/* pages/cart/index.wxss - 购物车页面样式 */

.cart-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* ===== 顶部操作栏 ===== */
.top-bar {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.top-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.edit-btn {
  font-size: 28rpx;
  color: #FF6B35;
}

/* ===== 购物车列表 ===== */
.cart-list {
  padding: 16rpx 0;
}

.cart-item {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

/* ===== 选择框 ===== */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #DDDDDD;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.checkbox-checked {
  background: #FF6B35;
  border-color: #FF6B35;
}

.checkbox-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ===== 商品图片 ===== */
.item-img-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F5F5F5;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
}

/* ===== 商品信息 ===== */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.item-price-wrap {
  display: flex;
  align-items: baseline;
}

.item-price-symbol {
  font-size: 22rpx;
  color: #FF4444;
  font-weight: bold;
}

.item-price {
  font-size: 32rpx;
  color: #FF4444;
  font-weight: bold;
}

.item-subtotal {
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: right;
}

/* ===== 数量控制 ===== */
.qty-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1;
}

.qty-btn-min text {
  font-size: 24rpx;
}

.qty-btn-disabled {
  opacity: 0.35;
}

.qty-num {
  width: 64rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
  border-left: 1rpx solid #EEEEEE;
  border-right: 1rpx solid #EEEEEE;
  line-height: 56rpx;
}

/* ===== 空购物车 ===== */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #AAAAAA;
  margin-bottom: 48rpx;
}

.go-shopping-btn {
  background: #FF6B35;
  border-radius: 48rpx;
  padding: 20rpx 72rpx;
}

.go-shopping-btn text {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ===== 底部结算栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.all-check-wrap {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.all-check-label {
  font-size: 28rpx;
  color: #333333;
  margin-left: 12rpx;
}

/* 删除按钮（编辑模式） */
.delete-btn {
  flex: 1;
  height: 80rpx;
  background: #FF4444;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.delete-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 结算区域 */
.checkout-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #333333;
}

.total-symbol {
  font-size: 24rpx;
  color: #FF4444;
  font-weight: bold;
}

.total-price {
  font-size: 40rpx;
  color: #FF4444;
  font-weight: bold;
}

.checkout-btn {
  background: #FF4444;
  border-radius: 40rpx;
  padding: 0 36rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
}

.checkout-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.checkout-btn-disabled {
  background: #CCCCCC;
}
