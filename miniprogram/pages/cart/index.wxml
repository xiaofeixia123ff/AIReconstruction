<!--pages/cart/index.wxml - 购物车页面-->
<view class="cart-page">

  <!-- 顶部操作栏 -->
  <view class="top-bar" wx:if="{{cartList.length > 0}}">
    <text class="top-title">购物车（{{cartList.length}}）</text>
    <text class="edit-btn" bindtap="toggleEditMode">{{editMode ? '完成' : '编辑'}}</text>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cartList.length > 0}}">
    <view
      class="cart-item"
      wx:for="{{cartList}}"
      wx:key="id"
    >
      <!-- 选择框 -->
      <view
        class="checkbox {{item.checked ? 'checkbox-checked' : ''}}"
        bindtap="toggleCheck"
        data-index="{{index}}"
      >
        <text class="checkbox-icon" wx:if="{{item.checked}}">✓</text>
      </view>

      <!-- 商品图片 -->
      <view class="item-img-wrap" bindtap="goToProduct" data-id="{{item.id}}">
        <image
          class="item-img"
          src="{{item.mainImage || ''}}"
          mode="aspectFill"
        />
      </view>

      <!-- 商品信息 -->
      <view class="item-info">
        <text class="item-name" bindtap="goToProduct" data-id="{{item.id}}">{{item.name}}</text>
        <view class="item-bottom">
          <view class="item-price-wrap">
            <text class="item-price-symbol">¥</text>
            <text class="item-price">{{item.priceStr}}</text>
          </view>
          <!-- 数量控制 -->
          <view class="qty-control">
            <view
              class="qty-btn {{item.quantity <= 1 ? 'qty-btn-min' : ''}}"
              bindtap="decreaseQty"
              data-index="{{index}}"
            >
              <text>{{item.quantity <= 1 ? '🗑' : '－'}}</text>
            </view>
            <text class="qty-num">{{item.quantity}}</text>
            <view
              class="qty-btn {{item.quantity >= item.stock ? 'qty-btn-disabled' : ''}}"
              bindtap="increaseQty"
              data-index="{{index}}"
            >
              <text>＋</text>
            </view>
          </view>
        </view>
        <!-- 小计 -->
        <text class="item-subtotal">小计：¥{{item.subtotalStr}}</text>
      </view>
    </view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:else>
    <text class="empty-emoji">🛒</text>
    <text class="empty-title">购物车还是空的</text>
    <text class="empty-desc">快去挑选你喜欢的商品吧</text>
    <view class="go-shopping-btn" bindtap="goShopping">
      <text>去逛逛</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view style="height: 160rpx;"></view>
</view>

<!-- 底部结算栏 -->
<view class="bottom-bar" wx:if="{{cartList.length > 0}}">
  <!-- 全选 -->
  <view class="all-check-wrap" bindtap="toggleAllCheck">
    <view class="checkbox {{allChecked ? 'checkbox-checked' : ''}}">
      <text class="checkbox-icon" wx:if="{{allChecked}}">✓</text>
    </view>
    <text class="all-check-label">全选</text>
  </view>

  <!-- 编辑模式：删除按钮 -->
  <view wx:if="{{editMode}}" class="delete-btn" bindtap="deleteChecked">
    <text>删除选中</text>
  </view>

  <!-- 正常模式：结算按钮 -->
  <view wx:else class="checkout-wrap">
    <view class="total-info">
      <text class="total-label">合计：</text>
      <text class="total-symbol">¥</text>
      <text class="total-price">{{totalPriceStr || '0.00'}}</text>
    </view>
    <view
      class="checkout-btn {{totalCount === 0 ? 'checkout-btn-disabled' : ''}}"
      bindtap="goCheckout"
    >
      <text>结算（{{totalCount}}）</text>
    </view>
  </view>
</view>
