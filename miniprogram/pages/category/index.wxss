/* pages/category/index.wxss - 分类页样式 */

.category-page {
  display: flex;
  height: 100vh;
  background: #F5F5F5;
}

/* ===== 左侧分类导航 ===== */
.category-nav {
  width: 180rpx;
  height: 100%;
  background: #F0F0F0;
  flex-shrink: 0;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 26rpx;
  color: #666666;
  background: #F0F0F0;
  transition: all 0.2s;
}

.nav-item-active {
  background: #FFFFFF;
  color: #FF4444;
  font-weight: bold;
}

.nav-active-bar {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #FF4444;
  border-radius: 0 3rpx 3rpx 0;
}

.nav-text {
  padding: 0 12rpx;
  text-align: center;
  line-height: 1.4;
}

/* ===== 右侧商品面板 ===== */
.product-panel {
  flex: 1;
  height: 100%;
  background: #FFFFFF;
}

/* 加载/空状态 */
.loading-wrap,
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  gap: 20rpx;
}

.loading-text,
.empty-text {
  font-size: 26rpx;
  color: #AAAAAA;
}

.empty-icon {
  font-size: 80rpx;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 12rpx;
  gap: 12rpx;
}

.product-card {
  width: calc(50% - 6rpx);
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-img-wrap {
  width: 100%;
  height: 200rpx;
  overflow: hidden;
  background: #F9F9F9;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.product-info {
  padding: 12rpx 14rpx 16rpx;
}

.product-name {
  font-size: 24rpx;
  color: #333333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.price-symbol {
  font-size: 22rpx;
  color: #FF4444;
  font-weight: bold;
}

.price-value {
  font-size: 30rpx;
  color: #FF4444;
  font-weight: bold;
}
