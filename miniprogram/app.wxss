/* app.wxss - 全局样式 */

/* 颜色变量 */
page {
  --primary-color: #FF6B35;
  --primary-light: #FFF0EB;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --border-color: #EEEEEE;
  --bg-color: #F5F5F5;
  --white: #FFFFFF;
  --price-color: #FF4444;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-color);
}

/* 重置 - 注意：WXSS 不支持 * 选择器，box-sizing 在各组件中单独设置 */

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* Flex 工具类 */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}

/* 文字工具类 */
.text-primary { color: var(--primary-color); }
.text-secondary { color: var(--text-secondary); }
.text-placeholder { color: var(--text-placeholder); }
.text-price { color: var(--price-color); font-weight: bold; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片样式 */
.card {
  background: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 主按钮 */
.btn-primary {
  background: var(--primary-color);
  color: var(--white);
  border-radius: 48rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}
.btn-primary::after {
  border: none;
}

/* 描边按钮 */
.btn-outline {
  background: var(--white);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 48rpx;
  padding: 18rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}
.btn-outline::after {
  border: none;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-placeholder);
}
.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.empty-state text {
  font-size: 28rpx;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-placeholder);
  font-size: 26rpx;
}

/* 价格展示 */
.price-wrap .price-symbol {
  font-size: 24rpx;
  color: var(--price-color);
}
.price-wrap .price-num {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--price-color);
}
.price-wrap .price-original {
  font-size: 24rpx;
  color: var(--text-placeholder);
  text-decoration: line-through;
  margin-left: 8rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
